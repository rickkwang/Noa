{
  "name": "noa",
  "private": true,
  "version": "1.0.14",
  "description": "A fully client-side Markdown note-taking app",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:budget": "npm run build && node scripts/check-budgets.mjs",
    "check:structure": "node scripts/check-architecture.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:smoke": "playwright test",
    "desktop:dev": "concurrently -k \"npm run dev -- --host 127.0.0.1 --port 3000\" \"wait-on tcp:127.0.0.1:3000 && electron .\"",
    "desktop:build": "BUILD_TARGET=desktop npm run build && electron-builder --dir --mac --arm64",
    "desktop:pack:mac": "BUILD_TARGET=desktop npm run build && electron-builder --mac dmg zip --arm64",
    "desktop:publish:release": "BUILD_TARGET=desktop npm run build && electron-builder --mac dmg zip --arm64 --publish always"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/pixelify-sans": "^5.2.7",
    "@fontsource/redaction-50": "^5.2.5",
    "@fontsource/work-sans": "^5.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "d3-force": "^3.0.0",
    "electron-updater": "^6.8.3",
    "fuse.js": "^7.1.0",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.40",
    "localforage": "^1.10.0",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.14.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "41.1.0",
    "electron-builder": "^26.8.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.noa.desktop",
    "productName": "Noa",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "rickkwang",
        "repo": "Noa",
        "releaseType": "release"
      }
    ]
  }
}
