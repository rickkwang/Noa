# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Desktop update and release metadata (for Electron CI publish).
GH_OWNER="your-github-owner"
GH_REPO="your-github-repo"

# Apple signing and notarization (required for public mac distribution).
APPLE_ID="your-apple-id@example.com"
APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
APPLE_TEAM_ID="ABCDE12345"
CSC_LINK="base64-or-url-to-p12"
CSC_KEY_PASSWORD="p12-password"
